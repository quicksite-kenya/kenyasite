{
  "entities": {
    "marketplaceItems": {
      "title": "Marketplace Item",
      "description": "A website listed for sale in the marketplace.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the website."
        },
        "category": {
          "type": "string",
          "enum": [
            "E-Commerce Platforms",
            "E-Learning Systems",
            "Social Media Websites",
            "Business Landing Pages",
            "Corporate & Business Sites",
            "Portfolio & Creative Sites",
            "Custom Web Applications",
            "Other Digital Assets"
          ],
          "description": "The type of website or digital asset."
        },
        "price": {
          "type": "string",
          "description": "The price of the website in KSh."
        },
        "desc": {
          "type": "string",
          "description": "A brief description of the website features."
        },
        "img": {
          "type": "string",
          "description": "The URL of the preview image."
        },
        "galleryImages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "An array of URLs for the project gallery."
        },
        "link": {
          "type": "string",
          "description": "The URL of the live demo."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the item was created."
        }
      },
      "required": ["name", "category", "price", "desc", "img", "createdAt"]
    },
    "inquiries": {
      "title": "Inquiry",
      "description": "A request for a service or digital consultation from a potential client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The client's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The client's professional email."
        },
        "phone": {
          "type": "string",
          "description": "The client's phone number (optional)."
        },
        "service": {
          "type": "string",
          "description": "The service they are interested in."
        },
        "message": {
          "type": "string",
          "description": "The client's project vision or message."
        },
        "status": {
          "type": "string",
          "enum": ["New", "Read", "Replied", "Closed"],
          "description": "The current status of the inquiry."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the inquiry was sent."
        },
        "source": {
          "type": "string",
          "description": "The source of the inquiry (e.g., contact-form, newsletter, server-api)."
        }
      },
      "required": ["name", "email", "service", "message", "createdAt", "status"]
    },
    "blogPosts": {
      "title": "Blog Post",
      "description": "A news article, product release, or feature update.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the post."
        },
        "subtitle": {
          "type": "string",
          "description": "A brief summary or subtitle."
        },
        "content": {
          "type": "string",
          "description": "The full HTML content of the post."
        },
        "img": {
          "type": "string",
          "description": "The URL of the featured image."
        },
        "date": {
          "type": "string",
          "description": "The display date (e.g., April 1, 2026)."
        },
        "category": {
          "type": "string",
          "enum": ["News", "Product Release", "Feature Update", "Insights"],
          "description": "The type of blog post."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the post was created."
        }
      },
      "required": ["title", "subtitle", "content", "img", "date", "category", "createdAt"]
    },
    "clientSites": {
      "title": "Client Website",
      "description": "A dynamic website managed for a client.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string", "format": "email" },
        "plan": {
          "type": "string",
          "enum": ["Starter Online Presence", "Customer Generator", "Growth System"]
        },
        "template": {
          "type": "string",
          "enum": ["Default", "Salon & Beauty", "Fitness & Gym", "Restaurant & Cafe", "Legal & Consulting", "Medical & Health", "Universal Professional"]
        },
        "businessName": { "type": "string" },
        "tagline": { "type": "string" },
        "aboutText": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "cta": { "type": "string" }
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "desc": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quote": { "type": "string" }
            }
          }
        },
        "pricing": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "plan": { "type": "string" },
              "price": { "type": "string" },
              "features": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "cta": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "btn": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "whatsapp": { "type": "string" },
            "email": { "type": "string" },
            "address": { "type": "string" },
            "mapUrl": { "type": "string" }
          }
        },
        "images": {
          "type": "object",
          "properties": {
            "logo": { "type": "string" },
            "hero": { "type": "string" },
            "gallery": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": {
          "type": "string",
          "enum": ["Draft", "Live"]
        },
        "customDomain": { 
          "type": "string",
          "description": "Primary custom domain for the client."
        },
        "custom_domains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of all mapped custom domains (e.g. ['elitegym.com', 'www.elitegym.com'])."
        },
        "subdomain": {
          "type": "string",
          "description": "The unique subdomain handle (e.g. gym)."
        },
        "template_type": {
          "type": "string",
          "description": "The type of template to render."
        },
        "subscriptionPlan": {
          "type": "string",
          "enum": ["Starter Presence", "Business Growth", "Pro Conversion System", "Enterprise SaaS System"],
          "description": "The active subscription tier."
        },
        "paymentStatus": {
          "type": "string",
          "enum": ["Paid", "Unpaid", "Grace Period", "Cancelled"],
          "description": "Current billing status."
        },
        "setupFee": { "type": "number" },
        "monthlyFee": { "type": "number" },
        "featuresEnabled": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of unlocked features for this client."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "businessName", "template", "plan", "status", "createdAt"]
    }
  },
  "firestore": {
    "/marketplaceItems/{itemId}": {
      "schema": "marketplaceItems",
      "description": "Collection of websites available for sale."
    },
    "/inquiries/{inquiryId}": {
      "schema": "inquiries",
      "description": "Collection of inquiries from clients."
    },
    "/blogPosts/{postId}": {
      "schema": "blogPosts",
      "description": "Collection of blog posts and news updates."
    },
    "/clientSites/{siteId}": {
      "schema": "clientSites",
      "description": "Collection of dynamic client websites."
    }
  }
}
