rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() && 
             // Temporarily allow if email matches, regardless of verification, 
             // but strictly check email_verified in production if possible.
             // Given the user is running in AI Studio, verification status might be inconsistent.
             (request.auth.token.email.lower() == "michaelmulili41@gmail.com" || 
              request.auth.token.email.lower() == "michael.mulili@quicksite.com" || 
              request.auth.token.email.lower() == "michael.michael@quicksite.com" ||
              request.auth.token.email.lower() == "quicksitekenya@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'service', 'message', 'createdAt', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.status in ['New', 'Read', 'Replied', 'Closed'];
    }

    function isValidClientSite(data) {
      // Basic core fields check
      return data.keys().hasAll(['clientName', 'businessName', 'template', 'plan', 'status', 'createdAt']) &&
             data.businessName is string && data.businessName.size() <= 100 &&
             data.status in ['Draft', 'Preview', 'Live'];
    }

    // --- Resource Routes ---

    match /marketplaceItems/{itemId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }
    
    match /inquiries/{inquiryId} {
      allow read, list, delete: if isVerifiedAdmin();
      allow create: if isValidInquiry(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isVerifiedAdmin() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                    request.resource.data.status in ['New', 'Read', 'Replied', 'Closed'];
    }
    
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /clientSites/{siteId} {
      allow get: if true;
      // Allow PUBLIC list/query for LIVE sites (needed for Multi-Domain lookups)
      // The client query MUST include .where('status', '==', 'Live')
      // For Client Portal, users can list their own pending sites.
      allow list: if isVerifiedAdmin() || (resource.data.status == 'Live') || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
      
      allow create: if isVerifiedAdmin() || (isSignedIn() && request.resource.data.clientEmail == request.auth.token.email && isValidClientSite(request.resource.data) && request.resource.data.createdAt == request.time);
      allow update: if isVerifiedAdmin() && isValidClientSite(request.resource.data) && 
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isVerifiedAdmin();
    }
  }
}
